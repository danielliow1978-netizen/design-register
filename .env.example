# ── DATABASE ──────────────────────────────────────────────────────────────────
# Local dev (SQLite): file:./prisma/dev.db
# Production (Supabase Postgres): postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="file:./prisma/dev.db"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-64-char-random-hex-string"
JWT_EXPIRES_IN="7d"

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Comma-separated allowed origins for CORS
CORS_ORIGINS="http://localhost:5173,https://your-app.vercel.app"

# ── EMAIL (Resend) ─────────────────────────────────────────────────────────────
# Get free API key at https://resend.com (100 emails/day, 3000/month)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Email address to send digests FROM (must be verified domain in Resend)
EMAIL_FROM="noreply@yourdomain.com"

# ── FRONTEND URL ──────────────────────────────────────────────────────────────
# Used in email links
FRONTEND_URL="http://localhost:5173"
